{
  "id": "prompt-cleanup",
  "name": "Prompt Cleanup",
  "description": "Prompt refinement workspace — rewrite, improve, and validate prompts",
  "requiredPlugins": ["mock-llm-connector", "mock-output-validator", "mock-audit-logger"],
  "layout": "split",
  "defaultPanels": [
    {
      "id": "input-panel",
      "pluginId": "mock-llm-connector",
      "blockId": "chat-view",
      "position": { "col": 1, "row": 1, "colSpan": 6, "rowSpan": 10 }
    },
    {
      "id": "output-panel",
      "pluginId": "mock-output-validator",
      "blockId": "validator-panel",
      "position": { "col": 7, "row": 1, "colSpan": 6, "rowSpan": 10 }
    }
  ]
}
