# Morphius environment variables — copy to .env and adjust paths

# Port the backend listens on (default: 7900)
# MORPHIUS_PORT=7900

# Directory containing all sibling repos (Morphius_Host, Morphius_ModuleRuntime, etc.)
# Defaults to the parent of the Morphius repo — works out of the box if repos are siblings
# MORPHIUS_SIBLINGS_DIR=C:\Users\leven\repo

# Shared deps pool — set this to Morphius_Dependencies/data/node_modules once you
# have run "INSTALL ALL MISSING" inside the Dependencies umbrella.
# Until then, better-sqlite3 resolves via the Windows junction in Morphius_Host/module/node_modules/
# MORPHIUS_SHARED_DEPS_PATH=C:\Users\leven\repo\Morphius_Dependencies\data\node_modules

# Per-module data path overrides (normally auto-resolved — only set if you move data dirs)
# HOST_DATA_PATH=C:\Users\leven\repo\Morphius_Host\data
# MORPHIUS_DEPS_DATA_PATH=C:\Users\leven\repo\Morphius_Dependencies\data
